theorem triple_certs : ∀ p ∈ tripleData, (2 : ℚ) / 7 ≤ mgapQ (col (mkV p.1)) ![mkW p.2] := by
  native_decide

/-- **Finite n=3 classification (coords ≤ 30).** Every listed primitive triple
(≠ (1,2,3)) has `D ≤ 3/14`. -/
theorem triple_outside : ∀ p ∈ tripleData, D (mkV p.1) ≤ 3 / 14 :=
  fun p hp => D_le_of_certQ (mkV p.1) (mkW p.2) (triple_certs p hp)

/-- **No primitive triple with coords ≤ 30 (other than `(1,2,3)`) is in the
open band `(3/14, 1/4)`.** The bounded `S₁(3)` classification. -/
theorem triple_not_in_band :
    ∀ p ∈ tripleData, ¬ (3 / 14 < D (mkV p.1) ∧ D (mkV p.1) < 1 / 4) := by
  rintro p hp ⟨h1, _⟩
  exact absurd (triple_outside p hp) (not_le.mpr h1)

